declare(strict_types=1);

use Fisharebest\Webtrees\View;
use MagicSunday\Webtrees\DescendantsChart\Configuration;

/**
 * @var string        $javascript
 * @var Configuration $configuration
 * @var array         $id                The unique chart ID
 * @var array         $chartParams
 * @var string[]      $exportStylesheets A list of stylesheets used by SVG export
 * @var array         $data              The chart data
 */
?>

<div class="webtrees-descendants-chart-container" id="webtrees-descendants-chart-container-<?php echo $id; ?>"></div>

<?php View::push('javascript'); ?>
<script type="module">

import(<?php echo json_encode($javascript); ?>).then(({ DescendantsChart }) => {
    const opts = (typeof WebtreesDescendantsChart !== "undefined" && WebtreesDescendantsChart.chartOptions) || {};

    new DescendantsChart(
        "#webtrees-descendants-chart-container-<?php echo $id; ?>",
        {
            labels: <?php echo json_encode($chartParams['labels']); ?>,
            rtl: <?php echo json_encode($chartParams['rtl']); ?>,
            cssFiles: <?php echo json_encode($exportStylesheets); ?>,

            get generations() {
                return opts.generations ?? <?php echo $configuration->getGenerations(); ?>;
            },

            get treeLayout() {
                return opts.treeLayout ?? <?php echo json_encode($configuration->getLayout()); ?>;
            },

            get openNewTabOnClick() {
                return opts.openNewTabOnClick ?? <?php echo json_encode($configuration->getOpenNewTabOnClick()); ?>;
            },

            get showAlternativeName() {
                return opts.showAlternativeName ?? <?php echo json_encode($configuration->getShowAlternativeName()); ?>;
            },

            nameAbbreviation: <?php echo json_encode($chartParams['nameAbbreviation']); ?>,

            data: <?php echo json_encode($data); ?>
        }
    );
});

</script>
<?php View::endpush(); ?>
